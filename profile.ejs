<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile - emzy.com</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #0F172A;
            --primary: #6366F1;
            --accent: #EC4899;
            --cyan: #22D3EE;
            --text: #F8FAFC;
            --card: rgba(255, 255, 255, 0.06);
            --card-border: rgba(255, 255, 255, 0.18);
        }
        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }
        .card {
            background: var(--card);
            border: 1px solid var(--card-border);
            border-radius: 18px;
        }
        .profile-avatar {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border: 3px solid var(--primary);
        }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card p-4">
                    <div class="text-center mb-4">
                        <img src="<%= user.profilePic %>" alt="Profile Picture" class="profile-avatar rounded-circle mb-3">
                        <h2><%= user.name %></h2>
                        <p class="text-muted">ID: <%= user.id %></p>
                    </div>

                    <form method="POST" action="/update-profile">
                        <div class="mb-3">
                            <label for="bio" class="form-label">Bio</label>
                            <textarea class="form-control" id="bio" name="bio" rows="3"><%= user.bio %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Update Profile</button>
                    </form>

                    <hr>

                    <div class="row">
                        <div class="col-md-6">
                            <h4>Friends (<%= user.friends.length %>)</h4>
                            <div style="max-height: 200px; overflow-y: auto;">
                                <% user.friends.forEach(friendId => { %>
                                    <% const friend = users.find(u => u.id === friendId); %>
                                    <% if (friend) { %>
                                        <div class="d-flex align-items-center mb-2">
                                            <img src="<%= friend.profilePic %>" alt="<%= friend.name %>" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                            <span><%= friend.name %></span>
                                        </div>
                                    <% } %>
                                <% }); %>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h4>Blocked Users (<%= user.blocked.length %>)</h4>
                            <div style="max-height: 200px; overflow-y: auto;">
                                <% user.blocked.forEach(blockedId => { %>
                                    <% const blocked = users.find(u => u.id === blockedId); %>
                                    <% if (blocked) { %>
                                        <div class="d-flex align-items-center mb-2">
                                            <img src="<%= blocked.profilePic %>" alt="<%= blocked.name %>" class="rounded-circle me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                            <span><%= blocked.name %></span>
                                        </div>
                                    <% } %>
                                <% }); %>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <div class="text-center">
                        <a href="/dashboard" class="btn btn-secondary">Back to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>