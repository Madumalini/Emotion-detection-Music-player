<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to EMZY</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Bebas+Neue&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #050816;
            --accent: #22D3EE;
            --accent2: #EC4899;
            --text: #F8FAFC;
            --card: rgba(255, 255, 255, 0.08);
        }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Poppins', sans-serif;
            color: var(--text);
            background: url('/emotion-bg.jpg') center/cover no-repeat fixed;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .floating {
            position: absolute;
            border-radius: 50%;
            opacity: 0.45;
            filter: blur(14px);
            animation: float 18s ease-in-out infinite;
        }
        .floating:nth-child(1) { width: 240px; height: 240px; background: rgba(34, 211, 238, 0.35); top: 10%; left: 8%; animation-delay: 0s; }
        .floating:nth-child(2) { width: 200px; height: 200px; background: rgba(236, 72, 153, 0.32); top: 25%; left: 68%; animation-delay: 2s; }
        .floating:nth-child(3) { width: 260px; height: 260px; background: rgba(99, 102, 241, 0.28); top: 62%; left: 18%; animation-delay: 4s; }
        .floating:nth-child(4) { width: 220px; height: 220px; background: rgba(22, 163, 74, 0.28); top: 58%; left: 70%; animation-delay: 1s; }

        @keyframes float {
            0%, 100% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(-28px) scale(1.05); }
        }

        .card {
            position: relative;
            z-index: 1;
            width: min(420px, 90vw);
            padding: 2.4rem;
            border-radius: 24px;
            background: var(--card);
            border: 1px solid rgba(255,255,255,0.18);
            box-shadow: 0 20px 60px rgba(0,0,0,0.55);
            text-align: center;
        }

        .emoji {
            position: absolute;
            font-size: 2.2rem;
            opacity: 0;
            pointer-events: none;
            animation: floatEmoji 3s ease-in-out forwards;
        }

        @keyframes floatEmoji {
            0% { transform: translateY(12px) scale(0.95); opacity: 0; }
            40% { opacity: 1; }
            100% { transform: translateY(-240px) scale(1.2); opacity: 0; }
        }
        .brand {
            font-family: 'Bebas Neue', cursive;
            font-size: 3rem;
            letter-spacing: 0.16em;
            margin: 0;
            text-shadow: 0 0 18px rgba(99,102,241,0.7), 0 0 24px rgba(236,72,153,0.4);
            color: var(--accent);
        }
        .subtitle {
            margin: 0.75rem 0 2rem;
            opacity: 0.85;
            line-height: 1.4;
        }
        .btn-primary {
            padding: 0.9rem 1.8rem;
            font-size: 1.05rem;
            border-radius: 14px;
            border: none;
            cursor: pointer;
            background: linear-gradient(110deg, #f9d976, #f39f18);
            box-shadow: 0 12px 28px rgba(249, 211, 118, 0.25);
            color: #1f1a0a;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 34px rgba(249, 211, 118, 0.4);
        }
        .btn-primary:active {
            transform: translateY(1px);
            box-shadow: 0 10px 22px rgba(249, 211, 118, 0.35);
        }
        .fixed-btn {
            position: fixed;
            bottom: 28px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 2;
            min-width: 220px;
        }
        .small-text {
            margin-top: 1.4rem;
            opacity: 0.7;
            font-size: 0.93rem;
            line-height: 1.5;
        }
        a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div id="emojiContainer"></div>
    <div class="floating"></div>
    <div class="floating"></div>
    <div class="floating"></div>
    <div class="floating"></div>

    <button id="enterBtn" class="btn-primary fixed-btn">Get Started</button>

    <script src="/js/sounds.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.EMZY_Sound) {
                EMZY_Sound.bindGlobalInteractions();
                EMZY_Sound.playOpen();
            }

            const emojiContainer = document.getElementById('emojiContainer');
            const emojis = ['🎵', '🎶', '😊', '💖', '✨', '🎧', '🔥'];

            function spawnEmoji() {
                const el = document.createElement('div');
                el.className = 'emoji';
                el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
                el.style.left = `${10 + Math.random() * 80}%`;
                el.style.animationDuration = `${2.6 + Math.random() * 1.2}s`;
                emojiContainer.appendChild(el);

                el.addEventListener('animationend', () => el.remove());
            }

            const emojiInterval = setInterval(spawnEmoji, 420);
            setTimeout(() => clearInterval(emojiInterval), 4200);

            const enterBtn = document.getElementById('enterBtn');
            enterBtn.addEventListener('click', () => {
                if (window.EMZY_Sound) EMZY_Sound.playClick();
                window.location.href = '/login';
            });
        });
    </script>
</body>
</html>
