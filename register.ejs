<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMZY — Register</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #0F172A;
            --primary: #6366F1;
            --accent: #EC4899;
            --cyan: #22D3EE;
            --text: #F8FAFC;
            --card: rgba(255, 255, 255, 0.06);
            --card-border: rgba(255, 255, 255, 0.18);
        }

        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
            background: url('https://static.vecteezy.com/system/resources/thumbnails/048/802/034/small/natural-leather-structure-material-abstract-texture-background-for-design-natural-color-skin-material-fashion-design-wallpaper-black-wall-texture-background-for-graphic-design-and-web-design-photo.jpg') no-repeat center center fixed;
            background-size: cover;
            color: var(--text);
            position: relative;
        }
        body::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 25% 20%, rgba(99, 102, 241, 0.45), transparent 60%),
                        radial-gradient(circle at 75% 25%, rgba(236, 72, 153, 0.35), transparent 56%),
                        radial-gradient(circle at 55% 70%, rgba(34, 211, 238, 0.25), transparent 55%);
            opacity: 0.85;
            z-index: 0;
            filter: blur(10px);
        }
        body::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.18) 1px, transparent 1px);
            background-size: 44px 44px;
            opacity: 0.3;
            animation: float 25s linear infinite;
            z-index: 0;
        }
        body::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.18) 1px, transparent 1px);
            background-size: 50px 50px;
            opacity: 0.35;
            animation: float 25s linear infinite;
            z-index: 0;
        }
        @keyframes float {
            from { transform: translateY(0); }
            to { transform: translateY(-120px); }
        }
        .card {
            border-radius: 18px;
            background: var(--card);
            border: 1px solid var(--card-border);
            box-shadow: 0 16px 50px rgba(0, 0, 0, 0.55);
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            inset: -30px;
            background: radial-gradient(circle at 25% 25%, rgba(99, 102, 241, 0.35), transparent 50%),
                        radial-gradient(circle at 80% 35%, rgba(236, 72, 153, 0.3), transparent 55%);
            opacity: 0.6;
            filter: blur(24px);
            z-index: -1;
        }
        .logo {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 1rem;
        }
        .logo svg {
            width: 70px;
            height: 70px;
            filter: drop-shadow(0 0 24px rgba(99, 102, 241, 0.55))
                    drop-shadow(0 0 18px rgba(236, 72, 153, 0.45));
        }
        .brand {
            font-family: 'Bebas Neue', cursive;
            font-weight: 400;
            letter-spacing: 0.12em;
            text-shadow: 0 0 14px rgba(255, 255, 255, 0.35);
        }
        .form-control {
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: #f1f5fb;
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.18);
            box-shadow: 0 0 0 0.2rem rgba(76, 162, 230, 0.35);
        }
        .btn-primary {
            background: linear-gradient(130deg, #4b6cb7, #182848);
            border: none;
        }
        a {
            color: #a5d8ff;
        }
        a:hover {
            color: #fff;
        }
    </style>
</head>
<body>
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="card w-100" style="max-width: 450px;">
            <div class="card-body">
                <div class="logo">
                    <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="6"/>
                        <path d="M60 30 C70 30 80 40 80 55 C80 70 70 80 60 80 C50 80 40 70 40 55 C40 40 50 30 60 30 Z" fill="rgba(99,102,241,0.35)" />
                        <path d="M68 45 L68 70" stroke="#fff" stroke-width="5" stroke-linecap="round"/>
                        <path d="M68 55 L78 50" stroke="#fff" stroke-width="5" stroke-linecap="round"/>
                        <path d="M40 95 L80 95" stroke="rgba(99,102,241,0.55)" stroke-width="3" stroke-dasharray="6 6"/>
                    </svg>
                </div>
                <h1 class="brand text-center mb-2">EMZY</h1>
                <p class="text-center text-muted mb-4">Feel Your Music</p>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>
                <form action="/register" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="dob" class="form-label">Date of Birth</label>
                        <input type="date" class="form-control" id="dob" name="dob" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Register</button>
                </form>
                <p class="text-center text-muted mt-3">Already have an account? <a href="/login">Login</a></p>
            </div>
        </div>
    </div>

    <script src="/js/sounds.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.EMZY_Sound) {
                EMZY_Sound.bindGlobalInteractions();
                EMZY_Sound.playOpen();

                const form = document.querySelector('form');
                form?.addEventListener('submit', () => {
                    EMZY_Sound.playLogin();
                });
            }
        });
    </script>
</body>
</html>