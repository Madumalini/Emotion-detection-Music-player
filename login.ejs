<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMZY — Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --bg: #0F172A;
            --primary: #6366F1;
            --accent: #EC4899;
            --cyan: #22D3EE;
            --text: #fafdfe;
            --card: rgba(255, 255, 255, 0.06);
            --card-border: rgba(255, 255, 255, 0.18);
        }

        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
            background: url('/login-bg.jpeg') no-repeat center center fixed;
            background-size: cover;
            color: var(--text);
            position: relative;
        }

        body::before {
            /* Remove gradients for solid black background */
            display: none !important;
        }

        body::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.18) 1px, transparent 1px);
            background-size: 44px 44px;
            opacity: 0.3;
            animation: float 25s linear infinite;
            z-index: 0;
        }
        body::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,0.18) 1px, transparent 1px);
            background-size: 50px 50px;
            opacity: 0.35;
            animation: float 25s linear infinite;
            z-index: 0;
        }
        @keyframes float {
            from { transform: translateY(0); }
            to { transform: translateY(-120px); }
        }
        .card {
            border-radius: 18px;
            background: rgba(15, 23, 42, 0.88); /* strong dark overlay */
            border: 1px solid rgba(255,255,255,0.18);
            box-shadow: 0 16px 50px 8px rgba(0,0,0,0.85), 0 2px 16px 0 rgba(99,102,241,0.18);
            position: relative;
            z-index: 1;
            overflow: hidden;
        }

        .card::before {
            content: '';
            position: absolute;
            inset: -30px;
            background: radial-gradient(circle at 20% 20%, rgba(99, 102, 241, 0.35), transparent 50%),
                        radial-gradient(circle at 80% 35%, rgba(236, 72, 153, 0.3), transparent 55%);
            opacity: 0.6;
            filter: blur(22px);
            z-index: -1;
        }
        .logo {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 1rem;
        }
        .logo svg {
            width: 70px;
            height: 70px;
            filter: drop-shadow(0 0 24px rgba(99, 102, 241, 0.55))
                    drop-shadow(0 0 18px rgba(236, 72, 153, 0.4));
        }
        .brand {
            font-family: 'Bebas Neue', cursive;
            font-weight: 400;
            letter-spacing: 0.16em;
            text-shadow: 0 0 18px #fff, 0 0 24px rgba(99, 102, 241, 0.7), 0 0 24px rgba(236, 72, 153, 0.4);
            color: #fff;
        }
        .form-control {
            background: rgba(255, 255, 255, 0.18);
            border: 1px solid rgba(255, 255, 255, 0.35);
            color: #fff;
            font-weight: 500;
        }
        .subtitle {
            color: #f9d976 !important;
            text-shadow: 0 0 12px rgba(249, 217, 118, 0.6), 0 0 8px rgba(249, 217, 118, 0.4);
        }
        .form-control:focus {
            background: rgba(255, 255, 255, 0.22);
            box-shadow: 0 0 0 0.2rem rgba(99, 102, 241, 0.55);
        }
        .btn-primary {
            background: linear-gradient(110deg, #f9d976, #f39f18);
            border: none;
            box-shadow: 0 12px 28px rgba(249, 211, 118, 0.25);
            color: #1f1a0a;
            font-weight: 600;
            padding: 0.9rem 1.8rem;
            border-radius: 14px;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 34px rgba(249, 211, 118, 0.4);
        }
        .btn-primary:active {
            transform: translateY(1px);
            box-shadow: 0 10px 22px rgba(249, 211, 118, 0.35);
        }
        a {
            color: #22D3EE;
            text-shadow: 0 0 8px #000, 0 0 12px #22D3EE;
        }
        a:hover {
            color: #EC4899;
            text-shadow: 0 0 12px #000, 0 0 16px #EC4899;
        }
        .form-check-input {
            width: 1.25em;
            height: 1.25em;
            background: rgba(255, 255, 255, 0.12);
            border: 1.5px solid rgba(99, 102, 241, 0.6);
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: inset 0 0 10px rgba(34, 211, 238, 0.2);
        }
        .form-check-input:checked {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.5), rgba(236, 72, 153, 0.4));
            border-color: rgba(34, 211, 238, 0.8);
            box-shadow: 0 0 15px rgba(34, 211, 238, 0.5), inset 0 0 10px rgba(34, 211, 238, 0.3);
        }
        .form-check-input:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: rgba(34, 211, 238, 0.9);
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.6), inset 0 0 10px rgba(34, 211, 238, 0.25);
        }
        .form-check-label {
            color: rgba(250, 253, 254, 0.9);
            font-weight: 500;
            margin-left: 0.5rem;
            cursor: pointer;
            user-select: none;
        }
    </style>
</head>
<body>
    <div class="container d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="card w-100" style="max-width: 450px;">
            <div class="card-body">
                <div class="logo">
                    <img src="/login-logo.jpeg" alt="EMZY Logo" style="width: 70px; height: 70px; border-radius: 50%; object-fit: cover; filter: drop-shadow(0 0 24px rgba(99, 102, 241, 0.55)) drop-shadow(0 0 18px rgba(236, 72, 153, 0.4));">
                </div>
                <h1 class="brand text-center mb-2">EMZY</h1>
                <p class="text-center mb-4 subtitle">Music That Understands You</p>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger" role="alert"><%= error %></div>
                <% } %>
                <form action="/login" method="POST">
                    <div class="mb-3">
                        <label for="name" class="form-label">Name</label>
                        <input type="text" class="form-control" id="name" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="dob" class="form-label">Date of Birth</label>
                        <input type="date" class="form-control" id="dob" name="dob" required>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="remember" name="remember">
                        <label class="form-check-label" for="remember">Remember me</label>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
                <p class="text-center text-muted mt-3">New user? <a href="/register">Register</a></p>
            </div>
        </div>
    </div>

    <script src="/js/sounds.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.EMZY_Sound) {
                EMZY_Sound.bindGlobalInteractions();
                EMZY_Sound.playOpen();

                const form = document.querySelector('form');
                form?.addEventListener('submit', () => {
                    EMZY_Sound.playLogin();
                });
            }
        });
    </script>
</body>
</html>